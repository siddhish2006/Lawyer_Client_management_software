# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
# Option 1: Use DATABASE_URL (recommended for hosted databases like Neon, Supabase, Railway)
DATABASE_URL=postgresql://username:password@host:port/database

# Option 2: Use individual database variables
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=lawyer_client_db

# Email Service (Optional)
EMAIL_API_KEY=
EMAIL_FROM=noreply@lawoffice.com

# SMS Service (Optional)
SMS_API_KEY=

# WhatsApp Service (Optional)
WHATSAPP_API_KEY=

# Gupshup WhatsApp (Optional)
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=
GUPSHUP_SOURCE_NUMBER=
GUPSHUP_API_BASE_URL=https://api.gupshup.io
GUPSHUP_WEBHOOK_TOKEN=
